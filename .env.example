# Copy to .env for local development (server.js doesn't auto-load .env files;
# either `export` these yourself or add a one-line dotenv require if you want
# that convenience locally). On Render, set these as real environment
# variables in the dashboard — see render.yaml, which sets them automatically
# if you deploy via Blueprint.

# Secret used to sign JWTs. Render's blueprint auto-generates this for you.
# If setting manually, use a long random string — never reuse this example.
TASKORA_JWT_SECRET=replace-with-a-long-random-string

# Where the JSON datastore lives. Leave unset for local dev (defaults to
# ./data next to the code). On Render, this should point at the mounted
# persistent disk path, e.g. /var/data.
DATA_DIR=

# Render sets PORT automatically — you don't need to set this yourself on
# Render. Only relevant if running locally on a non-default port.
PORT=3000
